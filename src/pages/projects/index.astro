---
import MainGridLayout from '../../layouts/MainGridLayout.astro'
import ProjectSection from '../../components/ProjectSection.astro'
import { Icon } from 'astro-icon/components'

interface ProjectItem {
  title: string
  description: string
  status: 'coming-soon' | 'available'
  icon: string
  href?: string
}

interface ProjectSectionData {
  category: string
  description: string
  items: ProjectItem[]
}

const projectSections: ProjectSectionData[] = [
  {
    category: 'Games',
    description: 'Small games you can play directly in your browser.',
    items: [
      {
        title: '2048',
        description: 'Slide numbered tiles on a grid to combine them and create the 2048 tile.',
        status: 'coming-soon',
        icon: 'material-symbols:grid-view-outline-rounded',
      },
      {
        title: '24 点',
        description: 'Use four numbers and basic arithmetic operations to make 24.',
        status: 'available',
        href: '/games/make-24/',
        icon: 'material-symbols:calculate-outline-rounded',
      },
    ],
  },
]
---

<MainGridLayout title="Projects" description="A collection of projects, experiments, and small things I have built.">
  <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">

      <p class="text-75 mb-8">
        A collection of projects, experiments, and small things I have built.
      </p>

      {
        projectSections.map((section) => (
          <div class="mb-6 last:mb-0">
            <ProjectSection
              category={section.category}
              description={section.description}
            >
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {
                  section.items.map((item) => {
                    const cardContent = (
                      <div class="card-base p-6 flex flex-col gap-3 h-full">
                        <div class="flex items-center gap-3">
                          <div class="w-10 h-10 rounded-lg flex items-center justify-center bg-[var(--btn-regular-bg)] shrink-0">
                            <Icon
                              name={item.icon}
                              class="text-[1.35rem] text-[var(--primary)]"
                            />
                          </div>
                          <h3 class="text-lg font-bold text-90">{item.title}</h3>
                        </div>
                        <p class="text-75 text-sm leading-relaxed">{item.description}</p>
                        <div class="mt-auto pt-3 flex items-center gap-2">
                          <span
                            class="inline-block px-3 py-1 text-xs font-medium rounded-full bg-[var(--btn-regular-bg)] text-[var(--btn-content)]"
                          >
                            {item.status === 'available' ? 'Play' : 'Coming Soon'}
                          </span>
                        </div>
                      </div>
                    )

                    if (item.href) {
                      return (
                        <a href={item.href} class="block transition active:scale-[0.98] hover:brightness-95 dark:hover:brightness-110">
                          {cardContent}
                        </a>
                      )
                    }
                    return cardContent
                  })
                }
              </div>
            </ProjectSection>
          </div>
        ))
      }

    </div>
  </div>
</MainGridLayout>
